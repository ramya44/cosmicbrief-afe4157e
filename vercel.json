{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cosmicbrief.com" }],
      "destination": "https://www.cosmicbrief.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/vedic/results",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|WhatsApp|Slackbot|TelegramBot|Discordbot|Pinterestbot|vkShare).*"
        }
      ],
      "destination": "/api/og-meta?path=/vedic/results"
    },
    {
      "source": "/birth-chart",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|WhatsApp|Slackbot|TelegramBot|Discordbot|Pinterestbot|vkShare).*"
        }
      ],
      "destination": "/api/og-meta?path=/birth-chart"
    },
    {
      "source": "/weekly/results",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|WhatsApp|Slackbot|TelegramBot|Discordbot|Pinterestbot|vkShare).*"
        }
      ],
      "destination": "/api/og-meta?path=/weekly/results"
    },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/vedic/:path*", "destination": "/index.html" },
    { "source": "/weekly/:path*", "destination": "/index.html" },
    { "source": "/get-birth-chart", "destination": "/index.html" },
    { "source": "/birth-chart", "destination": "/index.html" },
    { "source": "/compatibility", "destination": "/index.html" },
    { "source": "/life-arc", "destination": "/index.html" },
    { "source": "/yearly-forecast", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/$1/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
